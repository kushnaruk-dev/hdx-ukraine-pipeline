# ── Database ────────────────────────────────────────────────
DB_SERVER=localhost
DB_NAME=hdx_ukraine
DB_DRIVER=ODBC Driver 17 for SQL Server
# Leave blank to use Windows Auth (recommended on local machine)
DB_USER=
DB_PASSWORD=

# ── HDX API ─────────────────────────────────────────────────
# Get yours free at: https://data.humdata.org/user/register
HDX_API_KEY=your_hdx_api_key_here
HDX_SITE=prod

# ── Pipeline ─────────────────────────────────────────────────
# Folder where your local HDX files live (fallback if API is down)
LOCAL_DATA_DIR=./data/raw

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
