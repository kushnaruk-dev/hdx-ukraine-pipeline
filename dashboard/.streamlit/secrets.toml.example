# ── Local development ────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in values.
# For Streamlit Cloud deployment, paste these into the Secrets
# section of your app settings dashboard.
#
# DO NOT commit secrets.toml to GitHub.

[database]
server   = ".\\SQLEXPRESS"
database = "hdx_ukraine"
driver   = "ODBC Driver 17 for SQL Server"
# Leave user/password empty for Windows Auth (local only)
# Fill them in for cloud deployment using SQL Auth
user     = ""
password = ""
